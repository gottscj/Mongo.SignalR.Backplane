<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.1;net8.0;net9.0;net10.0</TargetFrameworks>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <Version>1.0.6</Version>
        <Authors>Jonas Gottschau</Authors>
        <Title>Mongo.SignalR.Backplane</Title>
        <PackageTags>MongoDB SignalR backplane</PackageTags>
        <Description>
            Mongo DB Backplane for signalr. uses tailable cursor for instant (almost) invocation notification 
        </Description>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <RepositoryUrl>https://github.com/gottscj/Mongo.SignalR.Backplane</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageProjectUrl>https://github.com/gottscj/Mongo.SignalR.Backplane</PackageProjectUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Copyright>Copyright © Jonas Gottschau</Copyright>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <ItemGroup>
      <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

    <ItemGroup>
      <!-- netstandard2.1 needs the NuGet package; net8+ gets SignalR from the shared framework -->
      <PackageReference Include="Microsoft.AspNetCore.SignalR.Core" Version="1.1.0" Condition="'$(TargetFramework)' == 'netstandard2.1'" />
      <FrameworkReference Include="Microsoft.AspNetCore.App" Condition="'$(TargetFramework)' != 'netstandard2.1'" />
      <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="7.0.0" />
      <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
      <PackageReference Include="MongoDB.Driver" Version="3.9.0" />
      <!-- Pin to a safe version to override the vulnerable 11.0.2 pulled in transitively -->
      <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    </ItemGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
            <_Parameter1>Mongo.SignalR.Backplane.Tests</_Parameter1>
        </AssemblyAttribute>
    </ItemGroup>
</Project>
